{# roles/dns/templates/named.conf.j2 — RH358 #}
options {
    listen-on port 53 { 127.0.0.1; {{ ansible_host }}; };
    directory       "/var/named";
    allow-query     { localhost; {{ lab_network }}; };
    recursion yes;
    dnssec-validation yes;
};

zone "{{ lab_domain }}" IN {
    type master;
    file "{{ lab_domain }}.zone";
    allow-update { none; };
};

include "/etc/named.rfc1912.zones";
include "/etc/named.root.key";
