{# roles/samba/templates/smb.conf.j2 — RH358 #}
[global]
   workgroup = {{ samba_workgroup }}
   server string = Lab Samba Server %v
   netbios name = services
   security = user
   map to guest = bad user
   log file = /var/log/samba/log.%m
   max log size = 1000

{% for share in samba_shares %}
[{{ share.name }}]
   comment = {{ share.comment }}
   path = {{ share.path }}
   public = {{ share.public }}
   writable = {{ share.writable }}
   browsable = yes
   guest ok = yes
   create mask = 0664
   directory mask = 0775

{% endfor %}
